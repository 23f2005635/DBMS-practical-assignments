SQL> SELECT c.Course_Name,
  2         CASE MAX(
  3              CASE e.Grade
  4                  WHEN 'A+' THEN 4
  5                  WHEN 'A'  THEN 3
  6                  WHEN 'B'  THEN 2
  7                  WHEN 'C'  THEN 1
  8              END)
  9              WHEN 4 THEN 'A+'
 10              WHEN 3 THEN 'A'
 11              WHEN 2 THEN 'B'
 12              WHEN 1 THEN 'C'
 13         END AS Max_Grade
 14  FROM Course c
 15  JOIN Enrollment e
 16  ON c.Course_Id = e.Course_Id
 17  GROUP BY c.Course_Name;

